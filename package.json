    "smoke:play-split": "tsx scripts/smoke-play-split.ts",
    "smoke:grain-address": "tsx scripts/smoke-grain-address.ts",
    "smoke:grit-tree": "tsx scripts/smoke-grit-tree.ts",
    "smoke:temporal": "tsx scripts/smoke-temporal.ts",
    "smoke:temporal-envelope": "tsx scripts/smoke-temporal-envelope.ts",
    "smoke:wellformed": "tsx scripts/smoke-wellformed.ts",
