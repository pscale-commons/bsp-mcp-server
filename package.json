    "smoke:gray": "tsx scripts/smoke-gray.ts",
    "smoke:group": "tsx scripts/smoke-group.ts",
    "smoke:gray-live": "tsx scripts/smoke-gray-live.ts",
    "smoke:grain-live": "tsx scripts/smoke-grain-live.ts",
    "smoke:group-live": "tsx scripts/smoke-group-live.ts",
    "smoke:group2b-live": "tsx scripts/smoke-group2b-live.ts",
    "smoke:spool-live": "tsx scripts/smoke-spool-live.ts",
    "smoke:genus": "node --import tsx ./scripts/smoke-genus-parity.ts",
