    "smoke:unit": "tsx scripts/smoke-bsp.ts",
    "smoke:floor": "tsx scripts/smoke-floor-align.ts",
    "smoke:dots": "tsx scripts/smoke-dots.ts",
    "smoke:parser": "tsx scripts/smoke-parser.ts",
    "smoke:sentinel": "tsx scripts/smoke-sentinel.ts",
    "smoke:session": "tsx scripts/smoke-session.ts",
    "smoke:wellknown": "tsx scripts/smoke-wellknown.ts",
    "smoke:federated": "tsx scripts/smoke-federated-live.ts",
    "smoke:federated-parser": "tsx scripts/smoke-federated-parser.ts",
    "smoke:wire-bsp": "tsx scripts/smoke-wire-bsp.ts",
    "smoke:read-gate": "tsx scripts/smoke-read-gate.ts",
    "smoke:pool-engage": "tsx scripts/smoke-pool-engage.ts",
